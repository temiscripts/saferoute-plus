# Copy this file to .env and fill in the real values.
# Never commit .env.

# --- Server ---
PORT=4000
NODE_ENV=development

# --- Database ---
DATABASE_PATH=./data/saferoute.sqlite

# --- Auth / OTP ---
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5

# --- OTP logging (Google Sheets) ---
# Paste your Apps Script deployment URL here. Leave blank to disable.
SHEETS_WEBHOOK_URL=

# --- SMS provider ---
# Supported: twilio | africastalking | termii | console
# Use "console" in dev to print OTPs to the server console instead of sending real SMS.
SMS_PROVIDER=console

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Africa's Talking (Nigerian-friendly alternative)
AFRICASTALKING_USERNAME=
AFRICASTALKING_API_KEY=
AFRICASTALKING_FROM=

# Termii (Nigerian)
TERMII_API_KEY=
TERMII_FROM=

# --- Maps provider ---
# Supported: google | osrm
# osrm uses the free public demo server (no API key required) — fine for hackathon dev.
MAPS_PROVIDER=osrm
GOOGLE_MAPS_API_KEY=
OSRM_BASE_URL=https://router.project-osrm.org

# --- Escalation engine ---
ESCALATION_ACK_WINDOW_SECONDS=30
DEADMAN_CHECKIN_INTERVAL_SECONDS=120
DEADMAN_TICK_INTERVAL_SECONDS=10
ACK_LINK_BASE_URL=http://localhost:5173/ack

# --- CORS ---
CORS_ORIGIN=*
